<mujoco model="asimov1_upper_body">
  <compiler angle="radian" autolimits="true" />
  <option timestep="0.002" integrator="implicitfast" />
  <default>
    <geom friction="1.0 0.005 0.0001" rgba="0.75 0.78 0.82 1" />
  </default>
  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" />
    <geom name="floor" type="plane" size="5 5 0.1" rgba="0.3 0.35 0.3 1" />
    <body name="waist_mount" pos="0 0 1.0">
      <geom type="cylinder" size="0.05 0.05" mass="50" />
      <body name="torso" pos="0 0 0.1">
        <joint name="waist_yaw_joint" axis="0 0 1" range="-1.57 1.57" damping="1.0" armature="0.05" limited="true" />
        <geom name="torso_geom" type="box" pos="0 0 0.15" size="0.09 0.13 0.15" mass="6.2" />
        <geom name="battery_pack" type="box" pos="0 -0.0 0.06" size="0.06 0.09 0.035" mass="2.0" contype="0" conaffinity="0" rgba="0.8 0.6 0.1 1" />
        <site name="imu" pos="0 0 0.15" />
        <body name="neck" pos="0 0 0.3">
          <joint name="neck_yaw_joint" axis="0 0 1" range="-1.57 1.57" damping="1.0" armature="0.01" limited="true" />
          <geom type="sphere" size="0.03" mass="0.15" contype="0" conaffinity="0" rgba="0.25 0.25 0.28 1" />
          <body name="head" pos="0 0 0.08">
            <joint name="neck_pitch_joint" axis="0 1 0" range="-0.79 0.79" damping="1.0" armature="0.01" limited="true" />
            <geom type="sphere" pos="0 0 0.054" size="0.09" mass="1.5" />
            <site name="camera_mount" pos="0.09 0 0.054" />
          </body>
        </body>
        <body name="left_shoulder" pos="0 0.16 0.26">
          <joint name="left_shoulder_pitch_joint" axis="0 1 0" range="-3.14 0.87" damping="1.0" armature="0.05" limited="true" />
          <geom type="sphere" size="0.03" mass="0.4" contype="0" conaffinity="0" rgba="0.25 0.25 0.28 1" />
          <body name="left_shoulder2" pos="0 0 0">
            <joint name="left_shoulder_roll_joint" axis="-1 0 0" range="-1.57 0" damping="1.0" armature="0.05" limited="true" />
            <geom type="sphere" size="0.03" mass="0.3" contype="0" conaffinity="0" rgba="0.25 0.25 0.28 1" />
            <body name="left_upper_arm" pos="0 0 0">
              <joint name="left_shoulder_yaw_joint" axis="0 0 1" range="-1.57 1.57" damping="1.0" armature="0.01" limited="true" />
              <geom type="capsule" fromto="0 0 -0.02 0 0 -0.18" size="0.04" mass="1.6" />
              <body name="left_forearm" pos="0 0 -0.2">
                <joint name="left_elbow_joint" axis="0 1 0" range="0 2.44" damping="1.0" armature="0.01" limited="true" />
                <geom type="capsule" fromto="0 0 -0.02 0 0 -0.17" size="0.035" mass="1.0" />
                <body name="left_hand" pos="0 0 -0.19">
                  <joint name="left_wrist_yaw_joint" axis="0 0 1" range="-3.14 3.14" damping="1.0" armature="0.01" limited="true" />
                  <geom type="box" pos="0 0 -0.04" size="0.03 0.02 0.05" mass="0.4" />
                </body>
              </body>
            </body>
          </body>
        </body>
        <body name="right_shoulder" pos="0 -0.16 0.26">
          <joint name="right_shoulder_pitch_joint" axis="0 -1 0" range="-0.87 3.14" damping="1.0" armature="0.05" limited="true" />
          <geom type="sphere" size="0.03" mass="0.4" contype="0" conaffinity="0" rgba="0.25 0.25 0.28 1" />
          <body name="right_shoulder2" pos="0 0 0">
            <joint name="right_shoulder_roll_joint" axis="-1 0 0" range="0 1.57" damping="1.0" armature="0.05" limited="true" />
            <geom type="sphere" size="0.03" mass="0.3" contype="0" conaffinity="0" rgba="0.25 0.25 0.28 1" />
            <body name="right_upper_arm" pos="0 0 0">
              <joint name="right_shoulder_yaw_joint" axis="0 0 1" range="-1.57 1.57" damping="1.0" armature="0.01" limited="true" />
              <geom type="capsule" fromto="0 0 -0.02 0 0 -0.18" size="0.04" mass="1.6" />
              <body name="right_forearm" pos="0 0 -0.2">
                <joint name="right_elbow_joint" axis="0 -1 0" range="-2.44 0" damping="1.0" armature="0.01" limited="true" />
                <geom type="capsule" fromto="0 0 -0.02 0 0 -0.17" size="0.035" mass="1.0" />
                <body name="right_hand" pos="0 0 -0.19">
                  <joint name="right_wrist_yaw_joint" axis="0 0 1" range="-3.14 3.14" damping="1.0" armature="0.01" limited="true" />
                  <geom type="box" pos="0 0 -0.04" size="0.03 0.02 0.05" mass="0.4" />
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
  <contact>
    <exclude body1="torso" body2="left_upper_arm" />
    <exclude body1="torso" body2="right_upper_arm" />
  </contact>
  <actuator>
    <motor name="waist_yaw" joint="waist_yaw_joint" ctrlrange="-120 120" />
    <motor name="neck_yaw" joint="neck_yaw_joint" ctrlrange="-36 36" />
    <motor name="neck_pitch" joint="neck_pitch_joint" ctrlrange="-36 36" />
    <motor name="left_shoulder_pitch" joint="left_shoulder_pitch_joint" ctrlrange="-90 90" />
    <motor name="left_shoulder_roll" joint="left_shoulder_roll_joint" ctrlrange="-75 75" />
    <motor name="left_shoulder_yaw" joint="left_shoulder_yaw_joint" ctrlrange="-60 60" />
    <motor name="left_elbow" joint="left_elbow_joint" ctrlrange="-36 36" />
    <motor name="left_wrist_yaw" joint="left_wrist_yaw_joint" ctrlrange="-36 36" />
    <motor name="right_shoulder_pitch" joint="right_shoulder_pitch_joint" ctrlrange="-90 90" />
    <motor name="right_shoulder_roll" joint="right_shoulder_roll_joint" ctrlrange="-75 75" />
    <motor name="right_shoulder_yaw" joint="right_shoulder_yaw_joint" ctrlrange="-60 60" />
    <motor name="right_elbow" joint="right_elbow_joint" ctrlrange="-36 36" />
    <motor name="right_wrist_yaw" joint="right_wrist_yaw_joint" ctrlrange="-36 36" />
  </actuator>
  <sensor>
    <jointpos name="waist_yaw_joint_pos" joint="waist_yaw_joint" />
    <jointvel name="waist_yaw_joint_vel" joint="waist_yaw_joint" />
    <jointpos name="neck_yaw_joint_pos" joint="neck_yaw_joint" />
    <jointvel name="neck_yaw_joint_vel" joint="neck_yaw_joint" />
    <jointpos name="neck_pitch_joint_pos" joint="neck_pitch_joint" />
    <jointvel name="neck_pitch_joint_vel" joint="neck_pitch_joint" />
    <jointpos name="left_shoulder_pitch_joint_pos" joint="left_shoulder_pitch_joint" />
    <jointvel name="left_shoulder_pitch_joint_vel" joint="left_shoulder_pitch_joint" />
    <jointpos name="left_shoulder_roll_joint_pos" joint="left_shoulder_roll_joint" />
    <jointvel name="left_shoulder_roll_joint_vel" joint="left_shoulder_roll_joint" />
    <jointpos name="left_shoulder_yaw_joint_pos" joint="left_shoulder_yaw_joint" />
    <jointvel name="left_shoulder_yaw_joint_vel" joint="left_shoulder_yaw_joint" />
    <jointpos name="left_elbow_joint_pos" joint="left_elbow_joint" />
    <jointvel name="left_elbow_joint_vel" joint="left_elbow_joint" />
    <jointpos name="left_wrist_yaw_joint_pos" joint="left_wrist_yaw_joint" />
    <jointvel name="left_wrist_yaw_joint_vel" joint="left_wrist_yaw_joint" />
    <jointpos name="right_shoulder_pitch_joint_pos" joint="right_shoulder_pitch_joint" />
    <jointvel name="right_shoulder_pitch_joint_vel" joint="right_shoulder_pitch_joint" />
    <jointpos name="right_shoulder_roll_joint_pos" joint="right_shoulder_roll_joint" />
    <jointvel name="right_shoulder_roll_joint_vel" joint="right_shoulder_roll_joint" />
    <jointpos name="right_shoulder_yaw_joint_pos" joint="right_shoulder_yaw_joint" />
    <jointvel name="right_shoulder_yaw_joint_vel" joint="right_shoulder_yaw_joint" />
    <jointpos name="right_elbow_joint_pos" joint="right_elbow_joint" />
    <jointvel name="right_elbow_joint_vel" joint="right_elbow_joint" />
    <jointpos name="right_wrist_yaw_joint_pos" joint="right_wrist_yaw_joint" />
    <jointvel name="right_wrist_yaw_joint_vel" joint="right_wrist_yaw_joint" />
  </sensor>
</mujoco>